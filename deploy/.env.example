# Constructora Garibay — variables de entorno (deploy/.env)
# Copia este archivo a deploy/.env y rellena los valores.
# deploy/.env NUNCA se sube a git (ver deploy/.gitignore).

# ── Cloudflare Tunnel ──────────────────────────────────────
# Token del tunnel. Lo imprime scripts/cf-tunnel-setup.mjs al crear el tunnel,
# o lo encuentras en el dashboard de Cloudflare:
#   Zero Trust → Networks → Tunnels → (tu tunnel) → Configure → token.
CLOUDFLARED_TOKEN=

# ── Solo para correr scripts/cf-tunnel-setup.mjs ───────────
# (No los necesita el contenedor; son para el bootstrap una sola vez.)
#
# API token con permisos:
#   Account · Cloudflare Tunnel · Edit
#   Zone · DNS · Edit   (sobre la zona constructoragaribay.com)
CF_API_TOKEN=
# Account ID: dashboard de Cloudflare → barra lateral derecha, o el primer
# segmento de la URL del dashboard.
CF_ACCOUNT_ID=
# Zone ID: dashboard del dominio → Overview → "Zone ID" en la barra derecha.
CF_ZONE_ID=
# Dominio raíz (opcional, default abajo).
CF_DOMAIN=constructoragaribay.com
